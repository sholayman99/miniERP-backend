# --- Application ---
NODE_ENV=development
PORT=5000
# Comma-separated not needed; set to your deployed frontend URL in production
ADMIN_URL=http://localhost:3001

# --- Database ---
# Use MongoDB Atlas (replica set) — required for sale transactions
MONGODB_URI=mongodb://localhost:27017/erp

# --- JWT ---
JWT_ACCESS_SECRET=change_me_use_a_strong_random_secret_min_16_chars
JWT_ACCESS_TTL_MIN=1440

# --- Cloudinary (required for product image upload) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Observability ---
LOG_LEVEL=debug

# --- Optional: override seeded admin credentials ---
# SEED_ADMIN_EMAIL=admin@erp.test
# SEED_ADMIN_PASSWORD=Admin@123
